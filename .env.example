# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DISABLE_OUTBOUND_SMS=
INTERNAL_WORKER_SECRET=
INTAKE_RATE_LIMIT_PER_IP=
INTAKE_RATE_LIMIT_PER_COMPANY=
INTAKE_RATE_LIMIT_WINDOW_MS=
INTAKE_STATUS_RATE_LIMIT_PER_IP=
INTAKE_STATUS_RATE_LIMIT_PER_TOKEN=
INTAKE_STATUS_RATE_LIMIT_WINDOW_MS=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tech action token secret — generate with: openssl rand -base64 32
TECH_TOKEN_SECRET=

# Quote approval token secret (separate key). Falls back to TECH_TOKEN_SECRET if unset.
# Generate with: openssl rand -base64 32
QUOTE_TOKEN_SECRET=

# Sentry — create a Next.js project at sentry.io and paste the DSN here
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Internal-only demo seeding. Leave unset in production.
ENABLE_SEED_DEMO=

# Payment providers (stubbed — fill in when ready)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_REDIRECT_URI=
SQUARE_STATE_SECRET=
SQUARE_TOKEN_ENCRYPTION_KEY=

# Optional production-safe rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
